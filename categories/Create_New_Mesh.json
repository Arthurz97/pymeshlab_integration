{
  "__category_info__": {
    "description": "Tools and filters for generating new 3D meshes and primitives from scratch."
  },
  "create_cube": {
    "ui_name": "Box/Cube",
    "object_name": "Cube",
    "description": "Create a Box, Cube, Hexahedron. You can specify the side length.",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge",
      "sharp_face"
    ],
    "params": {
      "size": {
        "name": "Size",
        "description": "Scales the new mesh",
        "type": "float",
        "unit": "LENGTH",
        "default": 2.0,
        "min": 0.001,
        "soft_max": 10.0,
        "max": 5000.0,
        "precision": 4
      }
    }
  },
  "create_sphere": {
    "ui_name": "Sphere",
    "object_name": "Sphere",
    "description": "Create a Sphere, whose topology is obtained as regular subdivision of an icosahedron.",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge"
    ],
    "params": {
      "radius": {
        "name": "Radius",
        "description": "Radius of the sphere",
        "type": "float",
        "unit": "LENGTH",
        "default": 1.0,
        "min": 0.001,
        "precision": 4
      },
      "subdiv": {
        "name": "Subdiv. Level",
        "description": "Number of the recursive subdivision of the surface. Default is 3 (a sphere approximation composed by 1280 faces). Admitted values are in the range 0 (an icosahedron) to 8 (a 1.3 MegaTris approximation of a sphere)",
        "type": "int",
        "default": 3,
        "min": 0,
        "max": 8
      }
    }
  },
  "create_sphere_cap": {
    "ui_name": "Sphere Cap",
    "object_name": "Sphere_Cap",
    "description": "Create a Sphere Cap, or spherical dome, subtended by a cone of given angle.",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge"
    ],
    "params": {
      "angle": {
        "name": "Angle",
        "description": "Angle of the cone subtending the cap. It must be < 180.",
        "type": "float",
        "default": 60.0,
        "min": 0.001,
        "max": 179.99,
        "precision": 2
      },
      "subdiv": {
        "name": "Subdiv. Level",
        "description": "Number of the recursive subdivision of the surface. Default is 3 (a sphere approximation composed by 1280 faces). Admitted values are in the range 0 (an icosahedron) to 8 (a 1.3 MegaTris approximation of a sphere)",
        "type": "int",
        "default": 3,
        "min": 0,
        "max": 8
      }
    }
  },
  "create_torus": {
    "ui_name": "Torus",
    "object_name": "Torus",
    "description": "Create a Torus",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge"
    ],
    "params": {
      "hradius": {
        "name": "Horizontal Radius",
        "description": "Radius of the whole horizontal ring of the torus",
        "type": "float",
        "unit": "LENGTH",
        "default": 3.0,
        "min": 0.001,
        "precision": 4
      },
      "vradius": {
        "name": "Vertical Radius",
        "description": "Radius of the vertical section of the ring",
        "type": "float",
        "unit": "LENGTH",
        "default": 1.0,
        "min": 0.001,
        "precision": 4
      },
      "hsubdiv": {
        "name": "Horizontal Subdivision",
        "description": "Subdivision step of the ring",
        "type": "int",
        "default": 24,
        "min": 3
      },
      "vsubdiv": {
        "name": "Vertical Subdivision",
        "description": "Number of sides of the polygonal approximation of the torus section",
        "type": "int",
        "default": 12,
        "min": 3
      }
    }
  },
  "create_annulus": {
    "ui_name": "Annulus",
    "object_name": "Annulus",
    "description": "Create an Annulus e.g. a flat region bounded by two concentric circles, or a holed disk.",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge",
      "sharp_face"
    ],
    "params": {
      "internalradius": {
        "name": "Internal Radius",
        "description": "Internal Radius of the annulus",
        "type": "float",
        "unit": "LENGTH",
        "default": 0.5,
        "min": 0.001,
        "precision": 4
      },
      "externalradius": {
        "name": "External Radius",
        "description": "Externale Radius of the annulus",
        "type": "float",
        "unit": "LENGTH",
        "default": 1.0,
        "min": 0.001,
        "precision": 4
      },
      "sides": {
        "name": "Sides",
        "description": "Number of the sides of the poligonal approximation of the annulus",
        "type": "int",
        "default": 32,
        "min": 3
      }
    }
  },
  "create_cone": {
    "ui_name": "Cone",
    "object_name": "Cone",
    "description": "Create a Cone",
    "requires_selection": false,
    "shade_flat": true,
    "remove_attributes": [
      "custom_normal",
      "material_index",
      "sharp_edge"
    ],
    "params": {
      "r0": {
        "name": "Radius 1",
        "description": "Radius of the bottom circumference",
        "type": "float",
        "unit": "LENGTH",
        "default": 1.0,
        "min": 0.0,
        "precision": 4
      },
      "r1": {
        "name": "Radius 2",
        "description": "Radius of the top circumference",
        "type": "float",
        "unit": "LENGTH",
        "default": 2.0,
        "min": 0.0,
        "precision": 4
      },
      "h": {
        "name": "Height",
        "description": "Height of the Cone",
        "type": "float",
        "unit": "LENGTH",
        "default": 3.0,
        "min": 0.001,
        "precision": 4
      },
      "subdiv": {
        "name": "Side",
        "description": "Number of sides of the polygonal approximation of the cone",
        "type": "int",
        "default": 36,
        "min": 3
      }
    }
  }
}